{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/packages/ide-adapters/vscode"
            ],
            "outFiles": [
                "${workspaceFolder}/packages/ide-adapters/vscode/dist/**/*.js"
            ],
            "preLaunchTask": "npm: build - packages/ide-adapters/vscode"
        }
    ]
}
