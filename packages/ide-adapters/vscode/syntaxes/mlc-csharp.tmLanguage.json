{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Babel TCC - C# Traduzido",
  "scopeName": "source.mlc-csharp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#tradu-annotations" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mlc-csharp",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mlc-csharp",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mlc-csharp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mlc-csharp",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.mlc-csharp",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mlc-csharp",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.other.verbatim.mlc-csharp",
          "begin": "@\"",
          "end": "\"(?!\")",
          "patterns": [
            {
              "name": "constant.character.escape.mlc-csharp",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mlc-csharp",
          "match": "\\b(0[xX][0-9a-fA-F_]+|0[bB][01_]+|[0-9][0-9_]*(\\.[0-9_]+)?([eE][+-]?[0-9_]+)?[fFdDmMlLuU]?)\\b"
        }
      ]
    },
    "tradu-annotations": {
      "patterns": [
        {
          "name": "markup.italic.tradu.mlc-csharp",
          "match": "//\\s*tradu(\\[.*?\\])?:.*$"
        }
      ]
    }
  }
}
