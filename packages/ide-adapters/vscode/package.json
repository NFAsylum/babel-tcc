{
  "name": "babel-tcc",
  "displayName": "Babel TCC - MultiLingual Code",
  "description": "Visualize source code translated to your natural language. Keywords and identifiers are translated in real-time.",
  "version": "0.1.0",
  "publisher": "NFAsylum",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Education"
  ],
  "activationEvents": [
    "onLanguage:csharp",
    "onLanguage:python",
    "onFileSystem:babel-tcc-translated",
    "onFileSystem:babel-tcc-readonly"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "babel-tcc.toggle",
        "title": "Babel TCC: Toggle Translation"
      },
      {
        "command": "babel-tcc.selectLanguage",
        "title": "Babel TCC: Select Language"
      },
      {
        "command": "babel-tcc.openTranslatedEditable",
        "title": "Babel TCC: Traduzir Codigo (Editavel)"
      },
      {
        "command": "babel-tcc.openTranslatedReadonly",
        "title": "Babel TCC: Traduzir Codigo (Readonly)"
      },
      {
        "command": "babel-tcc.showOriginal",
        "title": "Babel TCC: Show Original Code"
      }
    ],
    "configuration": {
      "title": "Babel TCC",
      "properties": {
        "babel-tcc.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable real-time translation."
        },
        "babel-tcc.language": {
          "type": "string",
          "default": "pt-br",
          "description": "Target natural language for translation."
        },
        "babel-tcc.translationsPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the babel-tcc-translations repository. If empty, auto-detects as sibling folder of the workspace or uses embedded translations."
        },
        "babel-tcc.readonly": {
          "type": "boolean",
          "default": false,
          "description": "Open translated views in readonly mode (prevents accidental edits to the original file)."
        }
      }
    },
    "grammars": [
      {
        "language": "mlc-csharp",
        "scopeName": "source.mlc-csharp",
        "path": "./syntaxes/mlc-csharp.tmLanguage.json"
      },
      {
        "language": "mlc-python",
        "scopeName": "source.mlc-python",
        "path": "./syntaxes/mlc-python.tmLanguage.json"
      }
    ],
    "languages": [
      {
        "id": "mlc-csharp",
        "aliases": [
          "C# Traduzido",
          "mlc-csharp"
        ],
        "extensions": []
      },
      {
        "id": "mlc-python",
        "aliases": [
          "Python Traduzido",
          "mlc-python"
        ],
        "extensions": []
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "npm run build && vsce package",
    "publish-core": "dotnet publish ../../core/MultiLingualCode.Core.Host/MultiLingualCode.Core.Host.csproj -c Release -o bin",
    "prepackage": "npm run publish-core && npm run copy-translations",
    "copy-translations": "node -e \"const fs=require('fs');const p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>{const sp=p.join(s,f),dp=p.join(d,f);fs.statSync(sp).isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp)})};cp('../../core/MultiLingualCode.Core.Tests/TestData/translations','translations')\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  }
}
